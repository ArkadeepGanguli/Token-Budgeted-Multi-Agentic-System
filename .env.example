# Provider and model routing
SMALL_MODEL=qwen2:1.5b
LARGE_PROVIDER=groq
LARGE_MODEL=llama-3.1-8b-instant

# Ollama (small model)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=90

# Groq (large model)
# Set your key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=90

# Generation controls
MODEL_TEMPERATURE=0.2

# Task-class token budgets
SUMMARIZE_THRESHOLD=80
ESCALATION_MIN_TOKENS=280
BUDGET_SIMPLE=200
BUDGET_MODERATE=800
BUDGET_COMPLEX=3000

# Per-model token caps shown in dashboard
SMALL_MODEL_TOKEN_CAP=4000
LARGE_MODEL_TOKEN_CAP=2500

# Optional pricing knobs for savings estimate (USD per 1M tokens)
SMALL_MODEL_INPUT_USD_PER_1M=0.10
SMALL_MODEL_OUTPUT_USD_PER_1M=0.10
LARGE_MODEL_INPUT_USD_PER_1M=0.05
LARGE_MODEL_OUTPUT_USD_PER_1M=0.08
